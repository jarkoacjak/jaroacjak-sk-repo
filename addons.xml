<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<addon id="repository.jarkoacjak" name="jarkoacjak repo" version="1.0.0" provider-name="Jarko">
    <extension point="xbmc.addon.repository" name="jarkoacjak repo">
        <dir>
            <info compressed="false">https://jarkoacjak.github.io/jaroacjak-sk-repo/addons.xml</info>
            <checksum>https://jarkoacjak.github.io/jaroacjak-sk-repo/addons.xml.md5</checksum>
            <datadir zip="true">https://jarkoacjak.github.io/jaroacjak-sk-repo/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="sk">Jarkoacjak Doplnky</summary>
        <description lang="sk">Repozitár pre Flow Play, TV free a Počúvam Rádiá.</description>
        <platform>all</platform>
    </extension>
</addon>

<addon id="plugin.video.flow_play" name="Flow Play" version="1.0.0" provider-name="Jarko">
    <requires><import addon="xbmc.python" version="3.0.0"/></requires>
    <extension point="xbmc.python.pluginsource" library="main.py"><provides>video</provides></extension>
    <extension point="xbmc.addon.repository">
        <datadir zip="true">https://github.com/jarkoacjak/plugin.video.flow_play</datadir>
    </extension>
</addon>

<addon id="plugin.video.tv_free" name="TV free" version="1.0.0" provider-name="Jarko">
    <requires><import addon="xbmc.python" version="3.0.0"/></requires>
    <extension point="xbmc.python.pluginsource" library="main.py"><provides>video</provides></extension>
    <extension point="xbmc.addon.repository">
        <datadir zip="true">https://github.com/jarkoacjak/plugin.video.tv_free</datadir>
    </extension>
</addon>

<addon id="plugin.audio.pocuvam.radio" name="Počúvam Rádiá" version="1.0.0" provider-name="Jarko">
    <requires><import addon="xbmc.python" version="3.0.0"/></requires>
    <extension point="xbmc.python.pluginsource" library="main.py"><provides>audio</provides></extension>
    <extension point="xbmc.addon.repository">
        <datadir zip="true">https://raw.githubusercontent.com/jarkoacjak/plugin.audio.pocuvam.radio/main/</datadir>
    </extension>
</addon>

</addons>
